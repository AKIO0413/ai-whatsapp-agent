# ====== Server ======
PORT=3000
NODE_ENV=development

# ====== WhatsApp Cloud API (Meta) ======
# Create an app at https://developers.facebook.com/ and add the "WhatsApp" product.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
# Any random string you choose; used to verify webhook subscription
WHATSAPP_VERIFY_TOKEN=change-me-to-a-long-random-string
# Graph API version
WHATSAPP_API_VERSION=v20.0

# ====== OpenAI ======
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ====== Admin auth (very basic, demo only) ======
ADMIN_USER=admin
ADMIN_PASSWORD=admin

# ====== Mock mode ======
# When true, the server will NOT call WhatsApp/OpenAI and will simulate responses.
# Useful for the demo recording without burning API credits.
MOCK_MODE=true
